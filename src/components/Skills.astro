---

<section id="competences" class="section-padding skills-section">
  <div class="section-header" data-reveal>
    <div class="section-label">Compétences</div>
    <h2 class="section-title">
      Ma <span class="accent">stack</span> technique
    </h2>
  </div>

  <div class="skills-grid">
    {categories.map((cat, i) => (
      <div class="skill-card" data-reveal data-reveal-delay={`${0.1 + i * 0.1}`}>
        <div class="skill-card-header">
          <span class="skill-card-icon" set:html={cat.icon} />
          <h3 class="skill-card-title">{cat.title}</h3>
        </div>
        <div class="skill-tags">
          {cat.skills.map((s) => (
            <span class="skill-tag">
              <span class="skill-tag-icon" set:html={icons[s] || ""} />
              {s}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-section {
    padding: 120px 60px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section-header {
    width: 100%;
    max-width: 1100px;
    margin-bottom: 56px;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .accent {
    color: var(--accent);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    width: 100%;
    max-width: 1100px;
  }

  .skill-card {
    background: var(--surface);
    border-radius: 16px;
    padding: 32px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: border-color 0.3s, transform 0.3s;
  }

  .skill-card:hover {
    border-color: rgba(0, 229, 160, 0.15);
    transform: translateY(-3px);
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .skill-card-icon {
    color: var(--accent);
    display: flex;
    align-items: center;
  }

  .skill-card-title {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .skill-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    color: var(--text-secondary);
    transition: color 0.3s, background 0.3s, border-color 0.3s;
  }

  .skill-tag-icon {
    display: flex;
    align-items: center;
    opacity: 0.5;
    transition: opacity 0.3s;
  }

  .skill-card:hover .skill-tag {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .skill-card:hover .skill-tag-icon {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .skills-section {
      padding: 60px 24px;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-card {
      padding: 24px;
    }
  }
</style>
