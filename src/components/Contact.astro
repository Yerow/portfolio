---
const links = [
  { label: "Email", href: "mailto:contact@mohamed.dev", icon: "✉" },
  { label: "LinkedIn", href: "#", icon: "in" },
  { label: "GitHub", href: "#", icon: "⟨/⟩" },
];
---

<section id="contact" class="section-padding contact-section">
  <div data-reveal>
    <div class="section-label">Contact</div>
    <h2 class="contact-title">
      Un projet en tête<span class="accent">?</span>
    </h2>
    <p class="contact-subtitle">
      Discutons de votre projet. Je suis toujours ouvert à de nouvelles
      collaborations et opportunités.
    </p>
    <div class="contact-links">
      {links.map((c) => (
        <a href={c.href} class="contact-btn" target={c.href.startsWith("mailto") ? undefined : "_blank"} rel="noopener noreferrer">
          <span class="contact-icon">{c.icon}</span> {c.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 120px 60px;
    text-align: center;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .accent {
    color: var(--accent);
  }

  .contact-subtitle {
    font-size: 16px;
    line-height: 1.7;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto 40px;
  }

  .contact-links {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-btn {
    padding: 14px 28px;
    background: var(--surface);
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 14px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    transition: border-color 0.3s, transform 0.3s;
  }

  .contact-btn:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .contact-icon {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: 60px 24px;
    }

    .contact-links {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
